---
// Shared page shell: <head>, fonts, global CSS, top nav, footer, and a slot
// for page content. `active` is forwarded to the nav; `bodyClass` is optional.
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import '../styles/styles.css';
import '../styles/home-styles.css';
import '../styles/compat-styles.css';
import '../styles/guide-styles.css';

const { title = 'Mechlovin Studio — PCB Resource Hub', description = 'Specs, layouts, and firmware for every Mechlovin PCB.', active } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <TopNav active={active} />
  <slot />
  <Footer />
</body>
</html>
