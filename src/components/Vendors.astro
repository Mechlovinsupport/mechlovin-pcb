---
const { vendors = [] } = Astro.props;
const stockLabel = (s) => (s === 'in' ? 'In stock' : s === 'low' ? 'Low' : 'Out');
---
<section class="section" id="where-to-buy">
  <h2>Where to buy</h2>
  <div class="section-sub">{vendors.length} vendor{vendors.length === 1 ? '' : 's'}.</div>
  {vendors.length > 0 ? (
    <table class="vendor-table">
      <thead>
        <tr>
          <th>Vendor</th>
          <th style="width: 130px">Region</th>
          <th style="width: 110px">Stock</th>
          <th style="width: 90px">Price</th>
          <th style="width: 180px">Shipping</th>
          <th class="actions" style="width: 100px"></th>
        </tr>
      </thead>
      <tbody>
        {vendors.map((v) => (
          <tr>
            <td class="name">{v.name}</td>
            <td class="region">{v.region}</td>
            <td><span class={`stock ${v.stock}`}>{stockLabel(v.stock)}</span></td>
            <td class="price">{v.price}</td>
            <td class="ship">{v.shipping}</td>
            <td class="actions"><a href={v.url} class="btn btn-ghost btn-xs" target="_blank" rel="noopener">Visit ↗</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  ) : (
    <p class="section-sub">No vendors listed yet — add stores in the CMS.</p>
  )}
</section>
