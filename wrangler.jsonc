{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mechlovin-pcb",
  "main": "worker/index.js",
  "compatibility_date": "2024-11-06",
  // Serve the Astro static build (dist/) as assets. Requests that match a file
  // are served directly; anything else (e.g. /api/auth) runs the Worker below.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
